  box-shadow: 0 0 0 2px rgba(54,211,153,0.2);
}

/* Label */
label {
  font-weight: 500;
  margin-bottom: 5px;
  display: block;
}

/* Backdrop layer disable default */
.modal-backdrop {
  display: none !important;
}


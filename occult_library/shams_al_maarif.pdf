  border-radius: 12px;
  box-shadow: 0 0 15px rgba(0,0,0,0.5);
  transition: transform 0.3s ease;
  display: block;
}

.image-container img:hover { 
  transform: scale(1.05); 
}

/* RESPONSIVE FIX */
@media (max-width: 768px) {
  .image-container {
    float: none;             /* nonaktifkan float di layar kecil */
    margin: 0 auto 15px auto; /* tengah */
    max-width: 80%;          /* lebar lebih besar di mobile */
    text-align: center;
  }
  .image-container img {
    width: 100%;
    max-width: 300px;        /* biar tidak terlalu besar */
    margin: 0 auto;
  }
}

/* ====== MODAL POPUP CENTER FIX + FADE ZOOM ANIMATION (BOOTSTRAP FRIENDLY) ====== */
.modal {
  position: fixed;
  inset: 0;
  display: none;
  justify-content: center;
  align-items: center;
  background-color: rgba(0, 0, 0, 0.65);
  z-index: 2000 !important;
  overflow-x: hidden;
  overflow-y: auto;
  transition: opacity 0.3s ease;
  padding: 20px; /* agar tetap bisa scroll di mobile */
}

.modal.show {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  animation: fadeInZoom 0.25s ease forwards;
}

@keyframes fadeInZoom {
  from { opacity: 0; transform: scale(0.9) translateY(30px); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}
/* ====== Kontainer Modal ====== */
.modal-content {
  background: #1c1d21;
  color: #fff;
  border-radius: 10px;
  width: 95%;
  max-width: 550px;
  box-shadow: 0 0 25px rgba(0,0,0,0.5);
  overflow: hidden;
  border: 1px solid #333;
  animation: modalZoom 0.3s ease;
}

@keyframes modalZoom {
  from { transform: scale(0.85); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.modal-header {
  padding: 15px 20px;
  border-bottom: 1px solid #333;
  background: #222;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-header h5 {
  font-size: 18px;
  font-weight: 600;
  color: #36d399;
  margin: 0;
}

.modal-body {
  padding: 20px;
}

.modal-footer {
  border-top: 1px solid #333;
  background: #1a1a1a;
  padding: 15px 20px;
  display: flex;
  justify-content: flex-end;
  gap: 10px;
}

/* Tombol close */
.close {
  color: #fff;
  font-size: 24px;
  border: none;
  background: none;
  cursor: pointer;
  opacity: 0.8;
  transition: opacity 0.2s;
}
.close:hover {
  opacity: 1;
}

/* Tombol bootstrap look */
.btn {
  border: none;
  border-radius: 6px;
  font-size: 14px;
  padding: 8px 16px;

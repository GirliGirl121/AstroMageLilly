    margin-bottom: 1em;
  }

  article.content strong {
    font-weight: 700;
  }

  blockquote {
    background-color: #f1f1f1;
    border-left: 5px solid #ccc;
    padding: 1em 1.2em;
    margin: 1.5em 0;
